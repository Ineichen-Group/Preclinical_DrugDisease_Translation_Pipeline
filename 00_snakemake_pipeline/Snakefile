        r"""
        export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:$LD_LIBRARY_PATH"

        python -u {params.script_path} \
          --model-name-str "{params.model_name_str}" \
          --in-verified "{input.in_verified}" \
          --species-csv "{input.species}" \
          --pred-col-species "{params.pred_col_species}" \
          --pred-col-age "{params.pred_col_age}" \
          --out-csv "{output}" \
          > {log.out} 2> {log.err}
        """


shared = cfg["ner_inference"]["shared"]
chunk_pattern = (
    f"{shared['chunk_input_dir']}/"
    f"{shared['chunk_prefix']}" + "{chunk_id}"
    f"{shared['chunk_suffix']}"
)

OUTDIRS_BY_MODEL = {mt: cfg["ner_inference"]["models"][mt]["output_dir"] for mt in MODEL_TYPES}
PRED_BASE = os.path.commonpath(OUTDIRS_BY_MODEL.values())
# e.g. "/shares/.../08_IE_full_text/model_predictions"

# build a STRING pattern for outputs (note the literal {model_type} and {chunk_id})
INFER_OUTPUT_PATTERN = os.path.join(
    PRED_BASE,
    "{model_type}",
    "bert_predictions",
    f"annotated_BioLinkBERT-base_tuples_{CHUNK_PREFIX}" + "{chunk_id}.csv",
)

rule run_ner_inference:
    input:
        chunk=chunk_pattern
    output:
        INFER_OUTPUT_PATTERN
    params:
        model_name=lambda wc: cfg["ner_inference"]["models"][wc.model_type]["model_name"],
        model_path=lambda wc: cfg["ner_inference"]["models"][wc.model_type]["model_path"],
        output_dir=lambda wc: cfg["ner_inference"]["models"][wc.model_type]["output_dir"],
        suffix=lambda wc: f"chunk_{wc.chunk_id}"
    log:
        out = "logs/infer_{model_type}_chunk_{chunk_id}.out",
        err = "logs/infer_{model_type}_chunk_{chunk_id}.err"
    threads: 16
    resources:
        cpus_per_task=16,
        gpus_per_task=1,
        mem_mb=32000,
        runtime="72h"
    conda:
        "envs/bert_models.yaml"
    shell:
        r"""
        set -xeuo pipefail
        exec > >(tee -a {log.out}) 2> >(tee -a {log.err} >&2)
        export OMP_NUM_THREADS={threads}
        export MKL_NUM_THREADS={threads}
        export OPENBLAS_NUM_THREADS={threads}
        export NUMEXPR_NUM_THREADS={threads}
        export TOKENIZERS_PARALLELISM=true
        export RAYON_NUM_THREADS={threads}
        mkdir -p {params.output_dir}
        python -u /shares/animalwelfare.crs.uzh/Preclinical_Pipeline/08_IE_full_text/run_bert_ner_annotations.py \
            --test_data_input {input.chunk} \
            --output_dir {params.output_dir} \
            --output_file_suffix {params.suffix} \
            --model_name "{params.model_name}" \
            --model_path "{params.model_path}" \
            > {log.out} 2> {log.err}
        """

def clean_outdir(dataset):
    # strip any leading slash in config to be safe
    rel = cfg["clean_ner"][dataset]["output_clean"].lstrip("/")
    return os.path.join(CLEAN_BASE, rel)

rule clean_ner:
    input:
        # Get all chunk files for the specific dataset (e.g., animals_nr or strain)
        ner_chunks=lambda wc: expand(
            INFER_OUTPUT_PATTERN,
            model_type=wc.dataset,
            chunk_id=CHUNK_IDS,
        ),
    output:
        directory(CLEAN_OUTPUT_PATTERN),
        done   = CLEAN_DONE_PATTERN,
    params:
        ner_column=cfg["clean_ner"].get("ner_column", "ner_prediction_BioLinkBERT-base_normalized"),
        # this is what your script actually reads from
        ner_chunks_dir=lambda wc: cfg["clean_ner"][wc.dataset]["input_prediction"]
    log:
        out="logs/clean_ner_{dataset}.out",
        err="logs/clean_ner_{dataset}.err"
    conda: "envs/papermage.yaml"
    shell:
        r"""
        mkdir -p logs
        python -u /shares/animalwelfare.crs.uzh/Preclinical_Pipeline/08_IE_full_text/clean_ner_predictions.py \
            --input_dir {params.ner_chunks_dir} \
            --output_dir {output} \
            --ner_column {params.ner_column} \
            > {log.out} 2> {log.err}
        touch {output.done}
        """

ANIMALS_NR_DATASET = "animals_nr"
ANIMALS_NR_CLEAN_DIR = CLEAN_OUTPUT_PATTERN.format(dataset=ANIMALS_NR_DATASET)
ANIMALS_NR_DIR  = clean_outdir("animals_nr")

rule clean_animal_nr:
    input:
        ner_chunks_dir = os.path.join(CLEAN_BASE, cfg["clean_ner"]["animals_nr"]["output_clean"]),
        ner_done       = os.path.join(ANIMALS_NR_DIR, ".clean_done"),     # make sure clean_ner has finished
        methods_file = cfg["combine"]["output_jsonl"]
    output:
        output_dir = directory(cfg["clean_animal_nr"]["output_dir"]),
        output_file = cfg["clean_animal_nr"]["output_dir"] + "/doc_animals_nr_predictions_clean.csv"
    log:
        out = "logs/clean_animal_nr.out",
        err = "logs/clean_animal_nr.err"
    resources:
        mem_mb=68000,
        runtime="48h"
    conda: "envs/papermage.yaml"
    shell:
        r"""
        mkdir -p logs
        python -u /shares/animalwelfare.crs.uzh/Preclinical_Pipeline/08_IE_full_text/clean_animal_nr.py \
            --ner_dir {input.ner_chunks_dir} \
            --text_file {input.methods_file} \
            --output_dir {output.output_dir} \
            > {log.out} 2> {log.err}
        """

