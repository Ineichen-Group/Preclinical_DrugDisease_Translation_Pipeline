shared = cfg["ner_inference"]["shared"]
chunk_pattern = (
    f"{shared['chunk_input_dir']}/"
    f"{shared['chunk_prefix']}" + "{chunk_id}"
    f"{shared['chunk_suffix']}"
)

rule run_ner_inference:
    input:
        chunk=chunk_pattern
    output:
        "model_predictions/{model_type}/bert_predictions/test_annotated_BioLinkBERT-base_tuples_chunk_{chunk_id}.csv"
    params:
        model_name=lambda wc: cfg["ner_inference"]["models"][wc.model_type]["model_name"],
        model_path=lambda wc: cfg["ner_inference"]["models"][wc.model_type]["model_path"],
        output_dir=lambda wc: cfg["ner_inference"]["models"][wc.model_type]["output_dir"],
        suffix=lambda wc: f"chunk_{wc.chunk_id}"
    log:
        out = "logs/infer_{model_type}_chunk_{chunk_id}.out",
        err = "logs/infer_{model_type}_chunk_{chunk_id}.err"
    threads: 16
    resources:
        cpus_per_task=16,
        gpus_per_task=1,
        mem_mb=32000,
        runtime=500
    conda:
        "envs/bert_models.yaml"
    shell:
        r"""
        set -xeuo pipefail
        exec > >(tee -a {log.out}) 2> >(tee -a {log.err} >&2)
        export OMP_NUM_THREADS={threads}
        export MKL_NUM_THREADS={threads}
        export OPENBLAS_NUM_THREADS={threads}
        export NUMEXPR_NUM_THREADS={threads}
        export TOKENIZERS_PARALLELISM=true
        export RAYON_NUM_THREADS={threads}
        mkdir -p {params.output_dir}
        python -u ../08_IE_full_text/run_bert_ner_annotations.py \
            --test_data_input {input.chunk} \
            --output_dir {params.output_dir} \
            --output_file_suffix {params.suffix} \
            --model_name "{params.model_name}" \
            --model_path "{params.model_path}" \
            > {log.out} 2> {log.err}
        """

