wildcard_constraints:
    category = r"[^/]+",
    chunk_id = r"\d+"

rule run_regex_classification_chunk:
    """
    Run regex classification on ONE sentence chunk for ONE category.
    Writes a per-chunk CSV that will be merged later.
    """
    input:
        chunk=f"{CHUNK_DIR}/{CHUNK_PREF}{{chunk_id}}{CHUNK_SUF}"
    output:
        # e.g. regex_out/<category>/chunk_17/<category>_predictions.csv
        chunk_csv=os.path.join(
            cfg["regex_classification"]["output_dir"],
            "{category}",
            "chunk_{chunk_id}",
            "{category}_predictions.csv",
        )
    params:
        text_col   = cfg["regex_classification"]["text_col"],
        # per-chunk temp dir to isolate regex_runner's output
        tmp_dir=lambda wildcards: os.path.join(
            cfg["regex_classification"]["output_dir"],
            wildcards.category,
            f"chunk_{wildcards.chunk_id}"
        ),
        output_dir_root = shlex.quote(cfg["regex_classification"]["output_dir"])
    log:
        out = "logs/regex_classification.{category}.chunk_{chunk_id}.out",
        err = "logs/regex_classification.{category}.chunk_{chunk_id}.err"
    conda:
        "envs/papermage.yaml"
    resources:
        runtime = "72h",   # much smaller than 120h since we split
        mem_mb  = 32000    # per-job memory; tune as needed
    threads: 1
    shell:
        r"""
        mkdir -p {params.tmp_dir}
        # Run regex on the chunk into the per-chunk dir
        python /shares/animalwelfare.crs.uzh/Preclinical_Pipeline/08_IE_full_text/regex_runner.py \
            --df_path {input.chunk} \
            --category {wildcards.category} \
            --text_col {params.text_col} \
            --output_dir {params.tmp_dir} \
            --chunksize 50000 \
            --progress \
            > {log.out} 2> {log.err}
        """

rule merge_regex_classification:
    """
    Merge per-chunk CSVs into the final {category}_predictions.csv.
    Keeps the header from the first chunk and appends the rest without headers.
    """
    input:
        # all per-chunk outputs for this category
        lambda wildcards: expand(
            os.path.join(
                cfg["regex_classification"]["output_dir"],
                wildcards.category,
                "chunk_{chunk_id}",
                f"{wildcards.category}_predictions.csv"
            ),
            chunk_id=range(1, NUM_CHUNKS + 1)
        )
    output:
        os.path.join(cfg["regex_classification"]["output_dir"], "{category}_predictions.csv")
    log:
        out = "logs/regex_merge.{category}.out",
        err = "logs/regex_merge.{category}.err"
    resources:
        runtime = "1h",
        mem_mb  = 4000
    shell:
        r"""
        # Take header from the first file, then skip headers in the rest
        first="{input[0]}"
        out="{output}"
        tmp="$(mktemp)"

        # Write header
        head -n 1 "$first" > "$tmp"

        # Append all rows from all chunks, skipping header lines
        for f in {input}; do
            tail -n +2 "$f" >> "$tmp"
        done

        mv "$tmp" "$out"
        echo "Merged {wildcards.category} into $out" > {log.out}
        """

