configfile: "config.yaml"

from pathlib import Path
import os, json, shlex
from os.path import join

# Snakemake automatically loads config.yaml into `config`
cfg = config

# ---------- helpers ----------
def join_quoted(items):
    """Join a list into a shell-safe string with each element quoted."""
    items = items or []
    return " ".join(shlex.quote(str(x)) for x in items)

def opt_flag(flag, value):
    """Return `--flag value` only if value is non-empty."""
    return f"{flag} {value}" if value else ""

# Pre-compute strings for shell commands (quoted safely)
WRONG_CSVS_STR      = join_quoted(cfg.get("wrong_csvs", []))
WRONG_CSVS = cfg.get("wrong_csvs", [])
COMBINE_EXCLUDES    = join_quoted(cfg.get("wrong_csvs", []))
COMBINE_INNERS_JSON = json.dumps(cfg["combine"].get("inner_folders", []))  # JSON uses double quotes -> safe to single-quote in shell
COMBINE_SUBFOLDERS_JSON = json.dumps(cfg["combine"]["subfolders"])
COMBINE_INNERS_JSON     = json.dumps(cfg["combine"]["inner_folders"])

# --- CADMUS patterns ---
CADMUS_ROOT = Path(cfg["extract_cadmus_methods"]["cadmus_root"])
CADMUS_GLOB = cfg["extract_cadmus_methods"].get("cadmus_glob", "*/output")
CADMUS_DIRS = sorted(str(p) for p in CADMUS_ROOT.glob(CADMUS_GLOB) if p.is_dir())

# derive stable labels (use the parent dir name, e.g. "cadmus_pd")
def _label_for(p: str) -> str:
    return Path(p).parent.name

CADMUS_LABELS = [_label_for(p) for p in CADMUS_DIRS]
CADMUS_MAP    = dict(zip(CADMUS_LABELS, CADMUS_DIRS))

#print("CADMUS_DIRS:", CADMUS_DIRS)
#print("CADMUS_LABELS:", CADMUS_LABELS)

# shared output base (same dir for all jobs) + per-input marker to enable parallelism
OUT_BASE        = cfg["extract_cadmus_methods"]["cadmus_output"]
CADMUS_MARKER_PATTERN  = os.path.join(OUT_BASE, "job_done_{label}.flag")

# --- PMC patterns ---
def _label_for_pmc(p: str) -> str:
    return Path(p).name  

PMC_ROOT = Path(cfg["extract_pmc_methods"]["pmc_root"])
PMC_GLOB = cfg["extract_pmc_methods"].get("pmc_glob", "*_fulltext")
PMC_DIRS = sorted(str(p) for p in PMC_ROOT.glob(PMC_GLOB) if p.is_dir())

PMC_LABELS = [_label_for_pmc(p) for p in PMC_DIRS]
PMC_MAP    = dict(zip(PMC_LABELS, PMC_DIRS))

# shared output base (same dir for all jobs) + per-input marker to enable parallelism
PMC_OUT_BASE        = cfg["extract_pmc_methods"]["pmc_output"]
PMC_MARKER_PATTERN  = os.path.join(PMC_OUT_BASE, "job_done_{label}.flag")

# Optional helper if you use it; otherwise make wrong_csvs empty
def opt_flag(name, value):
    return f"{name} {shlex.quote(value)}" if value else ""

NER_DATASETS = ["strain", "animals_nr"]

MODEL_TYPES = cfg["ner_inference"]["model_types"]
NUM_CHUNKS  = int(cfg["ner_inference"]["shared"]["num_chunks"])
CHUNK_PREFIX = cfg["ner_inference"]["shared"]["chunk_prefix"]

INFERENCE_TARGETS = [
    join(cfg["ner_inference"]["models"][mt]["output_dir"],
         f"annotated_BioLinkBERT-base_tuples_{CHUNK_PREFIX}{cid}.csv")
    for mt in MODEL_TYPES
    for cid in range(1, NUM_CHUNKS + 1)
]

REGEX_CATEGORIES = config["regex_classification"]["categories"]

# --- Clean-ner output pattern (string) ---
CLEAN_BASE = cfg["clean_ner"]["shared"]["base_dir"]
# Full output dirs per dataset (absolute paths)
CLEAN_OUTDIRS = {
    d: os.path.join(CLEAN_BASE, cfg["clean_ner"][d]["output_clean"])
    for d in NER_DATASETS
}
# Pattern used by rules (still with wildcard)
CLEAN_OUTPUT_PATTERN = os.path.join(CLEAN_BASE, "{dataset}", "processed")
CHUNK_IDS = range(1, NUM_CHUNKS + 1)
# pattern for done flags
CLEAN_DONE_PATTERN = os.path.join(CLEAN_OUTPUT_PATTERN, ".clean_done")


# ---------- workflow ----------
rule all:
    input:
        expand(CADMUS_MARKER_PATTERN, label=CADMUS_LABELS), 
        cfg["regex_classification"]["output_dir"],
        expand(
            os.path.join(cfg["regex_classification"]["output_dir"], "{category}_predictions.csv"),
            category=REGEX_CATEGORIES
        ),
        expand(
            "{dir}/{file}",
            dir=cfg["regex_classification"]["output_dir"],
            file=cfg["regex_doc_level"]["output_files"]
        ),
        cfg["filter_age_sentences"]["output_file"],
        INFERENCE_TARGETS,
        expand(CLEAN_OUTPUT_PATTERN, dataset=NER_DATASETS),
        cfg["map_animal_nr_to_numeric"]["output_dir"] + "/animals_nr_predictions_numeric.csv",
        cfg["map_strain_values"]["output_file"],
        cfg["doc_level_age_mapping"]["out_csv"],
        cfg["map_affiliation_to_geolocation"]["output_file"]
        

rule extract_methods_pmc:
    output:
        done = PMC_MARKER_PATTERN  
    params:
        pmc_dir  = lambda wc: shlex.quote(PMC_MAP[wc.label]),
        output_base = lambda wc: shlex.quote(PMC_OUT_BASE),
        logs_dir    = lambda wc: shlex.quote(os.path.join(cfg["logs_base"], f"pmc_{wc.label}"))
    log:
        out = os.path.join(cfg["logs_base"], "extract_methods_pmc_{label}.out"),
        err = os.path.join(cfg["logs_base"], "extract_methods_pmc_{label}.err")
    threads: 2
    resources:
        cpus_per_task=8,
        mem_mb=8000,
        runtime="39h"
    conda:
        "envs/papermage.yaml"
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.logs_dir}

        # Run multi-folder PMC extraction
        python /shares/animalwelfare.crs.uzh/Preclinical_Pipeline/07_full_text_retrieval/extract_methods_from_bioc_json.py \
          --input_base {params.pmc_dir} \
          --output_base {params.output_base} \
          --logs_dir {params.logs_dir} \
        > {log.out} 2> {log.err}
        touch {output.done}
        """

rule extract_methods_cadmus:
    output:
        marker = CADMUS_MARKER_PATTERN
    params:
        cadmus_dir  = lambda wc: shlex.quote(CADMUS_MAP[wc.label]),
        wrong_csvs  = lambda wc: (
            "--wrong-csvs " + " ".join(shlex.quote(str(p)) for p in WRONG_CSVS)
            if WRONG_CSVS else ""
        ),
        output_base = lambda wc: shlex.quote(OUT_BASE),  # same target dir for all
        logs_base   = lambda wc: shlex.quote(os.path.join(cfg["logs_base"], f"cadmus_{wc.label}"))
    log:
        out = os.path.join(cfg["logs_base"], "extract_methods_cadmus_{label}.out"),
        err = os.path.join(cfg["logs_base"], "extract_methods_cadmus_{label}.err")
    threads: 8
    resources:
        cpus_per_task = 8,
        mem_mb        = 32000,
        runtime       = "96h"
    conda:
        "envs/papermage.yaml"
    shell:
        """
        set -euo pipefail
        mkdir -p {params.logs_base} {params.output_base}
    
        python /shares/animalwelfare.crs.uzh/Preclinical_Pipeline/07_full_text_retrieval/extract_methods_from_cadmus.py \
          --cadmus-dir {params.cadmus_dir} \
          {params.wrong_csvs} \
          --output-base {params.output_base} \
          --logs-base {params.logs_base} \
          > {log.out} 2> {log.err}
    
        # per-input completion marker
        touch {output.marker}
        """

rule combine_methods:
    input:
        cadmus_done = expand(CADMUS_MARKER_PATTERN, label=CADMUS_LABELS),
        pmc_done    = expand(PMC_MARKER_PATTERN, label=PMC_LABELS)
    output:
        cfg["combine"]["output_jsonl"]
    params:
        base_dir            = cfg["combine"]["base_dir"],
        output_file         = cfg["combine"]["output_jsonl"],
        subfolders_json     = json.dumps(cfg["combine"].get("subfolders", [])),
        inner_folders_json  = json.dumps(cfg["combine"].get("inner_folders", [])),
        # make sure this points to the right key in your config:
        exclude_csvs        = cfg["combine"].get("wrong_csvs", []),
        # pre-join and shell-quote each path
        exclude_csvs_joined = lambda wc: " ".join(shlex.quote(str(p)) for p in cfg["combine"].get("wrong_csvs", [])),
    log:
        out = os.path.join("logs", "combine_methods_out.log"),
        err = os.path.join("logs", "combine_methods_err.log")
    threads: 2
    resources:
        runtime       = "10h",
        mem_mb        = 32000,
    conda:
        "envs/papermage.yaml"
    shell:
        r"""
        set -euo pipefail
        mkdir -p "$(dirname {log.out})"; touch {log.out} {log.err}
        exec > >(stdbuf -oL tee -a {log.out}) 2> >(stdbuf -oL tee -a {log.err} >&2)
        echo "[START] $(date -Is) PWD=$(pwd) Host=$(hostname)"
    
        # your commands below all get logged:
        python -u /shares/animalwelfare.crs.uzh/Preclinical_Pipeline/07_full_text_retrieval/combine_parsed_methods.py \
          --base-dir {params.base_dir:q} \
          --subfolders-json {params.subfolders_json:q} \
          --inner-folders-json {params.inner_folders_json:q} \
          --exclude-csvs {params.exclude_csvs_joined} \
          --output-file {params.output_file:q}
    
        echo "[END] $(date -Is)"
        """

