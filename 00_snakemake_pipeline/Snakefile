configfile: "config.yaml"

import os, json, shlex

# Snakemake automatically loads config.yaml into `config`
cfg = config

# ---------- helpers ----------
def join_quoted(items):
    """Join a list into a shell-safe string with each element quoted."""
    items = items or []
    return " ".join(shlex.quote(str(x)) for x in items)

def opt_flag(flag, value):
    """Return `--flag value` only if value is non-empty."""
    return f"{flag} {value}" if value else ""

# Pre-compute strings for shell commands (quoted safely)
WRONG_CSVS_STR      = join_quoted(cfg.get("wrong_csvs", []))
COMBINE_SUBFOLDERS  = join_quoted(cfg["combine"].get("subfolders", []))
COMBINE_EXCLUDES    = join_quoted(cfg.get("wrong_csvs", []))
COMBINE_INNERS_JSON = json.dumps(cfg["combine"].get("inner_folders", []))  # JSON uses double quotes -> safe to single-quote in shell

# ---------- workflow ----------
rule all:
    input:
        directory(cfg["extract_pmc_methods"]["output_base"]),
        directory(cfg["output_base"]),
        cfg["combine"]["output_jsonl"],
        cfg["sentence_extraction"]["output_jsonl"]

rule extract_methods_pmc:
    output:
        directory(cfg["extract_pmc_methods"]["output_base"])
    params:
        input_base  = lambda wc: shlex.quote(cfg["extract_pmc_methods"]["input_base"]),
        output_base = lambda wc: shlex.quote(cfg["extract_pmc_methods"]["output_base"]),
        logs_dir    = lambda wc: shlex.quote(cfg["extract_pmc_methods"]["logs_dir"])
    log:
        out=os.path.join(cfg["extract_pmc_methods"]["logs_dir"], "extract_methods_pmc_out.log"),
        err=os.path.join(cfg["extract_pmc_methods"]["logs_dir"], "extract_methods_pmc_err.log")
    threads: 2
    resources:
        cpus_per_task=2,
        mem_mb=8000,
        runtime="1h"
    conda:
        "envs/papermage.yaml"
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.logs_dir}

        # Run multi-folder PMC extraction
        python ../07_full_text_retrieval/extract_methods_from_bioc_json.py \
          --input_base {params.input_base} \
          --output_base {params.output_base} \
          --logs_dir {params.logs_dir} \
        > {log.out} 2> {log.err}
        """


rule extract_methods:
    output:
        directory(cfg["output_base"])
    params:
        cadmus_dir = lambda wc: shlex.quote(cfg["cadmus_dir"]),
        wrong_csvs = lambda wc: opt_flag("--wrong-csvs", WRONG_CSVS_STR),
        output_base = lambda wc: shlex.quote(cfg["output_base"]),
        logs_base   = lambda wc: shlex.quote(cfg["logs_base"])
    log:
        out=os.path.join(cfg["logs_base"], "extract_methods_out.log"),
        err=os.path.join(cfg["logs_base"], "extract_methods_err.log")
    threads: 4
    resources:
        cpus_per_task=4,
        mem_mb=18000,
        runtime="2h"
    conda:
        "envs/papermage.yaml"
    shell:
        r"""
        set -euo pipefail
        # Prepare logs directory
        mkdir -p {params.logs_base}

        # Run extraction and redirect outputs
        python ../07_full_text_retrieval/extract_methods_from_cadmus.py \
          --cadmus-dir {params.cadmus_dir} \
          {params.wrong_csvs} \
          --output-base {params.output_base} \
          --logs-base {params.logs_base} \
        > {log.out} 2> {log.err}
        """

COMBINE_SUBFOLDERS_JSON = json.dumps(cfg["combine"]["subfolders"])
COMBINE_INNERS_JSON     = json.dumps(cfg["combine"]["inner_folders"])

rule combine_methods:
    input:
        cfg["output_base"]
    output:
        cfg["combine"]["output_jsonl"]
    params:
        base_dir     = shlex.quote(cfg["combine"]["base_dir"]),
        subfolders_j = opt_flag("--subfolders-json", shlex.quote(COMBINE_SUBFOLDERS_JSON)),
        inners_j     = opt_flag("--inner-folders-json", shlex.quote(COMBINE_INNERS_JSON)),
        excludes     = opt_flag("--exclude-csvs", COMBINE_EXCLUDES),
        output_file  = shlex.quote(cfg["combine"]["output_jsonl"])
    log:
        out = os.path.join("logs", "combine_methods_out.log"),
        err = os.path.join("logs", "combine_methods_err.log")
    threads: 2
    conda:
        "envs/papermage.yaml"
    shell:
        r"""
        mkdir -p logs
        python ../07_full_text_retrieval/combine_parsed_methods.py \
          --base-dir {params.base_dir} \
          {params.subfolders_j} \
          {params.inners_j} \
          {params.excludes} \
          --output-file {params.output_file} \
          > {log.out} 2> {log.err}
        """

rule extract_sentences:
    input:
        cfg["sentence_extraction"]["input_jsonl"]
    output:
        cfg["sentence_extraction"]["output_jsonl"]
    params:
        text_col = cfg["sentence_extraction"]["text_col"]
    log:
        out = "logs/extract_sentences.out",
        err = "logs/extract_sentences.err"
    conda:
        "envs/papermage.yaml"
    shell:
        """
        python ../07_full_text_retrieval/extract_sentences.py \
            --input_jsonl {input} \
            --text_col {params.text_col} \
            --output_jsonl {output} \
            > {log.out} 2> {log.err}
        """
