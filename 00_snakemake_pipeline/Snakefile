rule extract_age_llm_unsloth:
    input:
        cfg["extract_age_unsloth"]["input_file"]
    output:
        cfg["extract_age_unsloth"]["output_file"]
    log:
        out = "logs/extract_age_unsloth.out",
        err = "logs/extract_age_unsloth.err"
    params:
        # script + required args from config
        script_path     = "../08_IE_full_text/age_extraction_LLM.py",
        model_dir       = cfg["extract_age_unsloth"]["model_dir"],
        text_col        = cfg["extract_age_unsloth"]["text_col"],
        pmid_col        = cfg["extract_age_unsloth"]["pmid_col"],
        sentence_id_col = cfg["extract_age_unsloth"]["sentence_id_col"],
        filter_col      = cfg["extract_age_unsloth"]["filter_col"],
        filter_eq       = cfg["extract_age_unsloth"]["filter_eq"],
        log_path        = cfg["extract_age_unsloth"]["log_path"],
    threads: 16
    resources:
        cpus_per_task=16,
        mem_mb=32000,
        runtime=500
    conda:
        "envs/unsloth.yaml"
    shell:
        r"""
        export LD_LIBRARY_PATH="$CONDA_PREFIX/lib:$LD_LIBRARY_PATH"
        # put Triton / Torch-Inductor caches on node-local or per-job dirs
        export TRITON_CACHE_DIR="${{SLURM_TMPDIR:-/scratch/$USER/triton_cache}}/${{SLURM_JOB_ID:-$$}}"
        export TORCHINDUCTOR_CACHE_DIR="${{SLURM_TMPDIR:-/scratch/$USER/torchinductor_cache}}/${{SLURM_JOB_ID:-$$}}"
        mkdir -p "$TRITON_CACHE_DIR" "$TORCHINDUCTOR_CACHE_DIR"
        python -u {params.script_path} \
            --model-dir "{params.model_dir}" \
            --input-csv "{input}" \
            --output-csv "{output}" \
            --text-col "{params.text_col}" \
            --pmid-col "{params.pmid_col}" \
            --sentence-id-col "{params.sentence_id_col}" \
            --filter-col "{params.filter_col}" \
            --filter-eq "{params.filter_eq}" \
            --log-path "{params.log_path}" \
            > {log.out} 2> {log.err}
        """

